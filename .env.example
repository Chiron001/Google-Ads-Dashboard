# ─────────────────────────────────────────────────────────────────────────────
# Google Ads AI Dashboard — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Add authorized redirect URI: http://localhost:3000/api/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Google Ads API ────────────────────────────────────────────────────────────
# Apply at: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_DEVELOPER_TOKEN=your-developer-token

# Your Google Ads Customer ID (digits only, no dashes)
GOOGLE_CUSTOMER_ID=1234567890

# If accessing via MCC (Manager Account), set the MCC customer ID here
# GOOGLE_LOGIN_CUSTOMER_ID=9876543210

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
